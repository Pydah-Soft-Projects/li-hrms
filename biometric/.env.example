# Server Configuration
PORT=3000

# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/biometric_logs

# HRMS MongoDB (for export: employee name, department, division)
HRMS_MONGODB_URI=mongodb://localhost:27017/hrms

# HRMS Backend Configuration
BACKEND_URL=http://localhost:5000
HRMS_MICROSERVICE_SECRET_KEY=your-microservice-secret-key-here

# Sync Configuration
SYNC_INTERVAL_MINUTES=15

# Device "Live" in dashboard: lastSeenAt must be newer than this (milliseconds). Default 180000 = 3 minutes.
DEVICE_HEARTBEAT_STALE_MS=180000

# JSON backups are always written under DEVICE_ATTLOG_BACKUP_DIR (default: biometric/data/device-attlog-backups).
# S3 is optional: uploads run only after the local file is saved.
# DEVICE_ATTLOG_BACKUP_DIR=D:\\backups\\biometric-attlog

# Optional: after each ATTLOG backup JSON is written locally, also upload to S3
# ATTLOG_BACKUP_S3_ENABLED=true
# AWS_S3_BUCKET_NAME=your-bucket-name
# (alternatives: ATTLOG_BACKUP_S3_BUCKET or AWS_S3_BUCKET)
# ATTLOG_BACKUP_S3_PREFIX=device-attlog-backups/
# AWS_REGION=ap-south-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# MinIO / custom endpoint (optional):
# AWS_S3_ENDPOINT=http://localhost:9000
# AWS_S3_FORCE_PATH_STYLE=true

# When DeviceUser already exists for a PIN, push DATA UPDATE USERINFO to the same device if the terminal payload still mismatches DB (set false to disable)
# SYNC_STORED_DEVICEUSER_TO_TERMINAL=true

# API Security (optional - add authentication token if needed)
# API_KEY=your_secret_key_here
