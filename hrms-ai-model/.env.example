# HRMS AI Model Service (Python)
PORT=8080
HOST=0.0.0.0
# Optional: must match HRMS_AI_API_KEY on Node backend if set
# API_KEY=your_shared_secret
# HRMS Native AI runs by default (no external LLM).
# Optional embedded GGUF (pip install llama-cpp-python):
# HRMS_AI_USE_GGUF=true
# HRMS_AI_GGUF_MODEL_PATH=C:/models/your-model.gguf
# Optional Ollama (disabled unless you set HRMS_AI_USE_OLLAMA=true):
# HRMS_AI_USE_OLLAMA=false
# HRMS_AI_OLLAMA_URL=http://127.0.0.1:11434
# HRMS_AI_OLLAMA_MODEL=llama3.2
