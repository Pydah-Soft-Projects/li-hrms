# Database Configuration
MONGODB_URI=mongodb://localhost:27017/hrms

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here
# Access token lifetime (short-lived). Refresh token/session TTL keeps users signed in.
JWT_ACCESS_EXPIRE=15m
JWT_REFRESH_EXPIRE=7d
# Legacy long-lived JWT (deprecated — only for old integrations)
# JWT_EXPIRE=7d

# Session management (Redis + MongoDB fallback). Requires REDIS_HOST or uses Mongo AuthSession collection.
SESSION_SINGLE_DEVICE=true
SESSION_TTL_SECONDS=604800
LOGIN_RATE_LIMIT_MAX=20

# Redis (sessions + job queues)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=

# SSO (external app token login). URL of the auth gateway that verifies the token.
# Example: https://your-crm-backend.com/auth/verify-token
# SSO_VERIFY_URL=

# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:3000
# Public backend URL used in local file upload links (IP/host + port). Example: http://192.168.0.36:5000
BACKEND_PUBLIC_URL=http://localhost:5000
# Optional host override when BACKEND_PUBLIC_URL is not set (defaults to localhost)
# BACKEND_HOST=192.168.0.36

# Web Push (browser / PWA). Regenerate anytime: npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: or https: URL (see web-push docs).
# Keys below are sample dev keys generated for this repo example — rotate for production.
VAPID_PUBLIC_KEY=BACLMExvnICY3_8ciKLhVW1crPLbJuAnk-TqmugMlIi7KgvTblnhIaEfUa7NOg2APu9AFgmxN9tVQov5ADHVePw
VAPID_PRIVATE_KEY=Z3GthDPWW-CXQuobLr4T0AKD3b4JGfmfMe8iMuUb7vg
VAPID_SUBJECT=mailto:hrms@localhost

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=li-hrms-certificates

# Email Configuration (if using email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# SMS Configuration (if using SMS notifications)
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=your_sender_id

# Post-verify punch replay: HRMS calls the biometric microservice only (required).
# LEAVE_REGISTER_USED_LEDGER_DEBITS_ONLY=1  # Temporary: register Used column = ledger debits only
# BIOMETRIC_SERVICE_BASE_URL=http://localhost:4000
# BIOMETRIC_SERVICE_BASE_URL=http://18.143.242.233:4000
# HRMS_MICROSERVICE_SECRET_KEY must match the biometric service.
#
# MONGODB_BIOMETRIC_URI / MONGODB_ATLAS_BIOMETRIC_URI — optional; used only for attendance thumb reports UI
# (not used for post-verify replay).
