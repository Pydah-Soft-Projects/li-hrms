# Database Configuration
MONGODB_URI=mongodb://localhost:27017/hrms
# SQL_TYPE=mysql # 'mysql' or 'mssql'. Auto-detected by port (3306=mysql, 1433=mssql) if omitted.
SQL_SERVER=localhost
SQL_PORT=1433
SQL_DATABASE=HRMS
SQL_USER=your_username
SQL_PASSWORD=your_password
SQL_ENCRYPT=true
SQL_TRUST_SERVER_CERTIFICATE=true

# JWT Secret
JWT_SECRET=your_jwt_secret_key_here

# SSO (external app token login). URL of the auth gateway that verifies the token.
# Example: https://your-crm-backend.com/auth/verify-token
# SSO_VERIFY_URL=

# Server Configuration
PORT=5000
FRONTEND_URL=http://localhost:3000

# Web Push (browser / PWA). Regenerate anytime: npx web-push generate-vapid-keys
# VAPID_SUBJECT must be a mailto: or https: URL (see web-push docs).
# Keys below are sample dev keys generated for this repo example — rotate for production.
VAPID_PUBLIC_KEY=BACLMExvnICY3_8ciKLhVW1crPLbJuAnk-TqmugMlIi7KgvTblnhIaEfUa7NOg2APu9AFgmxN9tVQov5ADHVePw
VAPID_PRIVATE_KEY=Z3GthDPWW-CXQuobLr4T0AKD3b4JGfmfMe8iMuUb7vg
VAPID_SUBJECT=mailto:hrms@localhost

# AWS S3 Configuration (for file uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=li-hrms-certificates

# Email Configuration (if using email notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_email_password

# SMS Configuration (if using SMS notifications)
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=your_sender_id
